# =========================================================
# PT Digital Nusantara - Employee Management System
# Environment Variables Configuration
# =========================================================
# Copy this file to .env and customize the values:
#   Windows:  copy .env.example .env
#   Linux/Mac: cp .env.example .env
# =========================================================

# --- DATABASE (REQUIRED) ---
# MySQL host address. Use 'localhost' for local MySQL, or 'mysql' for Docker.
DB_HOST=localhost

# MySQL username. Default XAMPP/Local: 'root'.
DB_USER=root

# MySQL password. Leave empty if using XAMPP with no password.
# For Docker, use 'employee_pass'.
DB_PASSWORD=

# Database name. Must match the one created during setup.
DB_NAME=uts_employee_db

# --- AUTHENTICATION (REQUIRED) ---
# Secret key for JWT token signing. MUST be changed to a long random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_replace_with_random_64_char_string

# Secret key for session encryption. MUST be changed to a long random string.
SESSION_SECRET=your_session_secret_here_replace_with_random_64_char_string

# --- SERVER (OPTIONAL) ---
# HTTP port for the server. Default: 3000.
PORT=3000

# Node environment. Use 'production' for deployment, 'development' otherwise.
# NODE_ENV=development
