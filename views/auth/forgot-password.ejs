<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lupa Password | PT Digital Nusantara</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.45.0/tabler-icons.min.css">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: #f5f3f0; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .auth-card { background: #fff; border-radius: 16px; padding: 40px 32px; width: 100%; max-width: 400px; border: 1px solid #e8e6e3; }
    .auth-card h3 { font-size: 20px; font-weight: 700; text-align: center; margin-bottom: 6px; }
    .auth-card p { color: #777; font-size: 13px; text-align: center; margin-bottom: 24px; }
    .form-label { font-size: 13px; font-weight: 600; color: #444; margin-bottom: 5px; }
    .form-control { border-radius: 8px; border: 1px solid #ddd; padding: 11px 14px; font-size: 14px; font-family: inherit; }
    .form-control:focus { border-color: #5a7c6f; box-shadow: 0 0 0 3px rgba(90,124,111,0.08); outline: none; }
    .btn-auth { width: 100%; padding: 12px; background: #1a1a1a; color: #fff; border: none; border-radius: 8px; font-size: 14px; font-weight: 600; font-family: inherit; cursor: pointer; }
    .btn-auth:hover { background: #333; }
    .alert { border-radius: 8px; font-size: 13px; padding: 12px 14px; font-weight: 500; border: none; }
    .alert-danger { background: #fef2f2; color: #b91c1c; }
    .alert-success { background: #f0fdf4; color: #166534; }
    .back-link { display: block; text-align: center; margin-top: 16px; color: #5a7c6f; font-size: 13px; font-weight: 500; text-decoration: none; }
    .back-link:hover { text-decoration: underline; }
  </style>
</head>
<body>
<div class="auth-card">
  <h3>Lupa Password</h3>
  <p>Masukkan email untuk mereset password</p>
  <% if (locals.error) { %><div class="alert alert-danger mb-3"><%= error %></div><% } %>
  <% if (locals.resetSent) { %>
  <div class="alert alert-success">
    <strong>Link reset password:</strong><br>
    <a href="<%= resetLink %>" style="word-break:break-all;font-size:12px;color:#166534;"><%= resetLink %></a>
  </div>
  <a href="/auth/login" class="back-link">Kembali ke Login</a>
  <% } else { %>
  <form method="POST" action="/auth/forgot-password">
    <div class="mb-3"><label class="form-label">Email</label><input type="email" name="email" class="form-control" required placeholder="email@example.com"></div>
    <button type="submit" class="btn-auth mb-3">Kirim Link Reset</button>
    <a href="/auth/login" class="back-link">Kembali ke Login</a>
  </form>
  <% } %>
</div>
</body>
</html>
