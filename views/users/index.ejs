<%- include('../partials/header', { currentPage: 'users', title: 'Data User' }) %>
<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
  <div>
    <h4>Data User</h4>
    <p>Kelola akun pengguna sistem</p>
  </div>
  <a href="/auth/register" class="btn btn-primary btn-sm"><i class="ti ti-plus me-1"></i>Tambah User</a>
</div>
<form method="GET" action="/users" class="row g-2 mb-3">
  <div class="col-md-4">
    <div class="input-group">
      <span class="input-group-text" style="border-radius:10px 0 0 10px;"><i class="ti ti-search"></i></span>
      <input type="text" name="search" class="form-control" placeholder="Cari username, email..." value="<%= search %>">
    </div>
  </div>
  <div class="col-auto">
    <button type="submit" class="btn btn-primary">Cari</button>
    <a href="/users" class="btn btn-light">Reset</a>
  </div>
</form>
<div class="card">
  <div class="table-responsive">
    <table class="table">
      <thead>
        <tr><th>#</th><th>Username</th><th>Email</th><th>Role</th><th>Status</th><th>Karyawan</th><th>Last Login</th><th>Aksi</th></tr>
      </thead>
      <tbody>
        <% if (users.length === 0) { %><tr><td colspan="8" class="text-center py-5 text-muted"><i class="ti ti-user-shield fs-1 d-block mb-2 opacity-25"></i>Belum ada data user</td></tr><% } %>
        <% var offset = (page-1)*10; users.forEach((u, i) => { %>
        <tr>
          <td style="font-weight:600;color:#64748b;"><%= offset + i + 1 %></td>
          <td style="font-weight:600;"><%= u.username %></td>
          <td><%= u.email %></td>
          <td><span class="badge <%= u.role === 'Admin' ? 'bg-danger' : 'bg-primary' %>"><%= u.role %></span></td>
          <td><span class="badge <%= u.status === 'Active' ? 'bg-success' : 'bg-warning text-dark' %>"><%= u.status %></span></td>
          <td><%= u.employee_name || '-' %></td>
          <td><small class="text-muted"><%= u.last_login ? new Date(u.last_login).toLocaleString('id-ID') : '-' %></small></td>
          <td>
            <div class="btn-group btn-group-sm">
              <a href="/users/<%= u.id %>/edit" class="btn" style="background:#fef3c7;color:#d97706;border-color:#fde68a;"><i class="ti ti-edit"></i></a>
              <form method="POST" action="/users/<%= u.id %>/delete" style="display:inline" onsubmit="return confirm('Hapus user ini?')">
                <button class="btn" style="background:#fef2f2;color:#dc2626;border-color:#fecaca;"><i class="ti ti-trash"></i></button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% if (totalPages > 1) { %>
  <div class="card-footer d-flex justify-content-between align-items-center flex-wrap gap-2">
    <small class="text-muted">Menampilkan <%= users.length %> dari <%= total %> data</small>
    <nav><ul class="pagination mb-0">
      <% for (let p = 1; p <= totalPages; p++) { %>
      <li class="page-item <%= p === page ? 'active' : '' %>"><a class="page-link" href="?search=<%= search %>&page=<%= p %>"><%= p %></a></li>
      <% } %>
    </ul></nav>
  </div>
  <% } %>
</div>
<%- include('../partials/scripts') %>
