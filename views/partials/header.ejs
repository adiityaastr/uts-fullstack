<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %>PT Digital Nusantara</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.45.0/tabler-icons.min.css">
  <style>
    :root {
      --sidebar-width: 260px;
      --sidebar-collapsed: 0px;
      --topbar-height: 64px;
      --primary: #4f46e5;
      --primary-light: #6366f1;
      --primary-dark: #4338ca;
      --success: #059669;
      --warning: #d97706;
      --danger: #dc2626;
      --border-color: #e5e7eb;
      --card-shadow: 0 1px 3px 0 rgba(0,0,0,0.06), 0 1px 2px -1px rgba(0,0,0,0.06);
      --card-shadow-hover: 0 10px 15px -3px rgba(0,0,0,0.08), 0 4px 6px -4px rgba(0,0,0,0.06);
      --transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }
    [data-bs-theme="dark"] {
      --border-color: #374151;
      --card-shadow: 0 1px 3px 0 rgba(0,0,0,0.3);
      --card-shadow-hover: 0 10px 15px -3px rgba(0,0,0,0.4), 0 4px 6px -4px rgba(0,0,0,0.3);
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background: #f8fafc;
      color: #1e293b;
      -webkit-font-smoothing: antialiased;
      transition: var(--transition);
    }
    [data-bs-theme="dark"] body {
      background: #0f172a;
      color: #e2e8f0;
    }

    /* ===== SIDEBAR ===== */
    #sidebar {
      position: fixed; top: 0; left: 0; bottom: 0;
      width: var(--sidebar-width);
      background: linear-gradient(180deg, #1e1b4b 0%, #312e81 50%, #1e1b4b 100%);
      z-index: 1040;
      overflow-y: auto;
      overflow-x: hidden;
      transition: transform 0.3s ease, width 0.3s ease;
      display: flex; flex-direction: column;
    }
    #sidebar::-webkit-scrollbar { width: 0; }
    .sidebar-brand {
      display: flex; align-items: center; gap: 12px;
      padding: 24px 20px 20px;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      text-decoration: none;
    }
    .sidebar-brand-icon {
      width: 40px; height: 40px;
      background: linear-gradient(135deg, #818cf8, #6366f1);
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .sidebar-brand-icon i { color: #fff; font-size: 22px; }
    .sidebar-brand-text {
      color: #fff; font-weight: 700; font-size: 16px;
      line-height: 1.3; letter-spacing: -0.3px;
    }
    .sidebar-brand-text small {
      display: block; color: rgba(255,255,255,0.5);
      font-weight: 400; font-size: 11px;
    }
    .sidebar-nav {
      flex: 1; padding: 12px 12px;
      display: flex; flex-direction: column; gap: 2px;
    }
    .sidebar-nav .nav-link {
      display: flex; align-items: center; gap: 12px;
      padding: 11px 16px;
      border-radius: 10px;
      color: rgba(255,255,255,0.65);
      text-decoration: none;
      font-weight: 500; font-size: 14px;
      transition: var(--transition);
      position: relative;
    }
    .sidebar-nav .nav-link:hover {
      color: #fff;
      background: rgba(255,255,255,0.08);
    }
    .sidebar-nav .nav-link.active {
      color: #fff;
      background: linear-gradient(135deg, #6366f1, #7c3aed);
      box-shadow: 0 4px 12px rgba(99,102,241,0.4);
    }
    .sidebar-nav .nav-icon { font-size: 20px; width: 24px; text-align: center; flex-shrink: 0; }
    .sidebar-divider { height: 1px; background: rgba(255,255,255,0.08); margin: 12px 16px; }
    .sidebar-footer {
      padding: 16px 16px 24px;
      border-top: 1px solid rgba(255,255,255,0.08);
    }
    .sidebar-footer .nav-link {
      display: flex; align-items: center; gap: 12px;
      padding: 11px 16px;
      border-radius: 10px;
      color: rgba(255,255,255,0.5);
      text-decoration: none;
      font-weight: 500; font-size: 14px;
      transition: var(--transition);
    }
    .sidebar-footer .nav-link:hover {
      color: #fca5a5;
      background: rgba(239,68,68,0.1);
    }

    /* ===== MAIN ===== */
    #main-content {
      margin-left: var(--sidebar-width);
      min-height: 100vh;
      transition: margin-left 0.3s ease;
      display: flex; flex-direction: column;
    }

    /* ===== TOPBAR ===== */
    .topbar {
      height: var(--topbar-height);
      background: #fff;
      border-bottom: 1px solid var(--border-color);
      display: flex; align-items: center;
      padding: 0 24px;
      position: sticky; top: 0;
      z-index: 1030;
      gap: 16px;
      transition: var(--transition);
    }
    [data-bs-theme="dark"] .topbar {
      background: #1e293b;
    }
    .topbar-title { font-weight: 600; font-size: 15px; color: #64748b; }
    [data-bs-theme="dark"] .topbar-title { color: #94a3b8; }
    .topbar-spacer { flex: 1; }
    .topbar-actions { display: flex; align-items: center; gap: 8px; }
    .theme-toggle {
      width: 38px; height: 38px; border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      background: #f1f5f9; border: 1px solid var(--border-color);
      cursor: pointer; font-size: 18px; color: #64748b;
      transition: var(--transition);
    }
    .theme-toggle:hover { background: #e2e8f0; color: #334155; }
    [data-bs-theme="dark"] .theme-toggle { background: #334155; border-color: #475569; color: #94a3b8; }
    [data-bs-theme="dark"] .theme-toggle:hover { background: #475569; color: #e2e8f0; }

    .user-dropdown-btn {
      display: flex; align-items: center; gap: 10px;
      padding: 6px 14px 6px 6px;
      border-radius: 12px;
      background: #f8fafc; border: 1px solid var(--border-color);
      cursor: pointer; font-weight: 500; font-size: 14px;
      transition: var(--transition); color: #334155;
    }
    .user-dropdown-btn:hover { background: #f1f5f9; box-shadow: var(--card-shadow); }
    [data-bs-theme="dark"] .user-dropdown-btn { background: #1e293b; border-color: #475569; color: #e2e8f0; }
    [data-bs-theme="dark"] .user-dropdown-btn:hover { background: #334155; }
    .user-avatar {
      width: 32px; height: 32px; border-radius: 8px;
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-weight: 600; font-size: 14px;
      flex-shrink: 0;
    }
    .user-role-badge {
      font-size: 10px; padding: 2px 8px; border-radius: 6px;
      font-weight: 600; letter-spacing: 0.3px;
    }
    .dropdown-menu { border-radius: 12px; border: 1px solid var(--border-color); box-shadow: 0 10px 25px rgba(0,0,0,0.1); padding: 6px; }
    [data-bs-theme="dark"] .dropdown-menu { background: #1e293b; border-color: #334155; }
    [data-bs-theme="dark"] .dropdown-item { color: #e2e8f0; }
    [data-bs-theme="dark"] .dropdown-item:hover { background: #334155; color: #fff; }
    .dropdown-item { border-radius: 8px; padding: 8px 14px; font-size: 14px; transition: var(--transition); }

    /* ===== PAGE CONTENT ===== */
    .page-content { padding: 24px; flex: 1; }
    .page-header { margin-bottom: 24px; }
    .page-header h4 { font-weight: 700; font-size: 22px; letter-spacing: -0.4px; margin: 0; }
    .page-header p { color: #64748b; font-size: 14px; margin: 4px 0 0; }
    [data-bs-theme="dark"] .page-header p { color: #94a3b8; }

    /* ===== CARDS ===== */
    .card { border-radius: 14px; border: 1px solid var(--border-color); box-shadow: var(--card-shadow); transition: var(--transition); background: #fff; }
    [data-bs-theme="dark"] .card { background: #1e293b; }
    .card-header { border-bottom: 1px solid var(--border-color); padding: 16px 20px; background: transparent; border-radius: 14px 14px 0 0 !important; }
    [data-bs-theme="dark"] .card-header { border-color: #334155; }
    .card-body { padding: 20px; }
    .card-footer { border-top: 1px solid var(--border-color); padding: 14px 20px; background: transparent; border-radius: 0 0 14px 14px !important; }
    [data-bs-theme="dark"] .card-footer { border-color: #334155; }
    .stat-card {
      border-radius: 16px; padding: 24px;
      display: flex; align-items: center; gap: 18px;
      border: 1px solid var(--border-color);
      cursor: default;
      transition: var(--transition);
      background: #fff;
    }
    [data-bs-theme="dark"] .stat-card { background: #1e293b; }
    .stat-card:hover { transform: translateY(-2px); box-shadow: var(--card-shadow-hover); }
    .stat-icon {
      width: 52px; height: 52px; border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      font-size: 24px; flex-shrink: 0;
    }
    .stat-value { font-size: 28px; font-weight: 700; letter-spacing: -0.5px; line-height: 1; }
    .stat-label { color: #64748b; font-size: 13px; font-weight: 500; margin-top: 2px; }
    [data-bs-theme="dark"] .stat-label { color: #94a3b8; }

    /* ===== TABLE ===== */
    .table { margin: 0; }
    .table thead th {
      background: #f8fafc; font-weight: 600; font-size: 12px;
      text-transform: uppercase; letter-spacing: 0.5px;
      color: #64748b; border-bottom: 1px solid var(--border-color);
      padding: 12px 16px; white-space: nowrap;
    }
    [data-bs-theme="dark"] .table thead th { background: #0f172a; color: #94a3b8; }
    .table tbody td { padding: 14px 16px; font-size: 14px; vertical-align: middle; border-color: var(--border-color); }
    [data-bs-theme="dark"] .table tbody td { border-color: #334155; }
    .table tbody tr { transition: var(--transition); }
    .table tbody tr:hover { background: #f8fafc; }
    [data-bs-theme="dark"] .table tbody tr:hover { background: #1e293b; }

    /* ===== BADGES ===== */
    .badge { font-weight: 500; padding: 4px 10px; border-radius: 6px; font-size: 12px; letter-spacing: 0.2px; }

    /* ===== BUTTONS ===== */
    .btn { border-radius: 10px; font-weight: 500; font-size: 13px; padding: 8px 16px; transition: var(--transition); letter-spacing: 0.2px; }
    .btn-sm { border-radius: 8px; padding: 6px 12px; font-size: 12px; }
    .btn-primary { background: var(--primary); border-color: var(--primary); }
    .btn-primary:hover { background: var(--primary-dark); border-color: var(--primary-dark); transform: translateY(-1px); box-shadow: 0 4px 12px rgba(79,70,229,0.3); }
    .btn-group-sm .btn { border-radius: 8px; }
    .btn-group > .btn:not(:last-child) { margin-right: 1px; }

    /* ===== FORM ===== */
    .form-control, .form-select {
      border-radius: 10px; border: 1px solid var(--border-color);
      padding: 10px 14px; font-size: 14px; transition: var(--transition);
      background: #fff;
    }
    [data-bs-theme="dark"] .form-control, [data-bs-theme="dark"] .form-select {
      background: #0f172a; color: #e2e8f0; border-color: #334155;
    }
    .form-control:focus, .form-select:focus {
      border-color: var(--primary); box-shadow: 0 0 0 3px rgba(99,102,241,0.1);
    }
    .form-label { font-weight: 500; font-size: 13px; color: #475569; margin-bottom: 6px; }
    [data-bs-theme="dark"] .form-label { color: #94a3b8; }

    /* ===== ALERTS ===== */
    .alert { border-radius: 12px; border: none; font-weight: 500; font-size: 14px; padding: 14px 18px; }
    .alert-success { background: #ecfdf5; color: #065f46; }
    .alert-danger { background: #fef2f2; color: #991b1b; }
    [data-bs-theme="dark"] .alert-success { background: rgba(5,150,105,0.15); color: #6ee7b7; }
    [data-bs-theme="dark"] .alert-danger { background: rgba(220,38,38,0.15); color: #fca5a5; }

    /* ===== PAGINATION ===== */
    .pagination .page-link {
      border-radius: 8px; margin: 0 2px; font-weight: 500; font-size: 13px;
      padding: 6px 12px; border: 1px solid var(--border-color);
      color: #475569; transition: var(--transition);
    }
    [data-bs-theme="dark"] .pagination .page-link { background: #1e293b; border-color: #334155; color: #94a3b8; }
    .pagination .page-item.active .page-link {
      background: var(--primary); border-color: var(--primary); color: #fff; font-weight: 600;
    }
    .pagination .page-link:hover { background: #f1f5f9; }
    [data-bs-theme="dark"] .pagination .page-link:hover { background: #334155; }

    /* ===== DETAIL PAGE ===== */
    .detail-avatar {
      width: 140px; height: 140px; border-radius: 20px;
      object-fit: cover; background: linear-gradient(135deg, #e0e7ff, #c7d2fe);
      display: flex; align-items: center; justify-content: center;
    }
    .detail-info-table td { padding: 12px 16px; font-size: 14px; }
    .detail-info-table td:first-child { width: 180px; font-weight: 600; color: #64748b; background: #f8fafc; }
    [data-bs-theme="dark"] .detail-info-table td:first-child { background: #0f172a; color: #94a3b8; }

    /* ===== LOGIN PAGE ===== */
    .auth-page {
      min-height: 100vh;
      display: flex; align-items: center; justify-content: center;
      background: linear-gradient(135deg, #1e1b4b 0%, #312e81 40%, #4338ca 100%);
      position: relative; overflow: hidden;
    }
    .auth-page::before {
      content: ''; position: absolute; inset: 0;
      background: radial-gradient(circle at 20% 80%, rgba(99,102,241,0.3) 0%, transparent 50%),
                  radial-gradient(circle at 80% 20%, rgba(139,92,246,0.3) 0%, transparent 50%);
    }
    .auth-card {
      background: rgba(255,255,255,0.97);
      backdrop-filter: blur(20px);
      border-radius: 24px;
      padding: 40px;
      width: 100%; max-width: 440px;
      box-shadow: 0 25px 60px rgba(0,0,0,0.25);
      position: relative; z-index: 1;
    }
    [data-bs-theme="dark"] .auth-card { background: rgba(15,23,42,0.95); color: #e2e8f0; }
    .auth-card h3 { font-weight: 800; letter-spacing: -0.5px; margin: 0; }
    .auth-card .subtitle { color: #64748b; font-size: 14px; margin: 4px 0 28px; }
    [data-bs-theme="dark"] .auth-card .subtitle { color: #94a3b8; }
    .auth-card .form-control { padding: 12px 16px; font-size: 15px; }
    .auth-card .btn { padding: 12px; font-size: 15px; font-weight: 600; border-radius: 12px; }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 768px) {
      #sidebar { transform: translateX(-100%); }
      #sidebar.open { transform: translateX(0); }
      #main-content { margin-left: 0 !important; }
      .mobile-overlay {
        display: none; position: fixed; inset: 0;
        background: rgba(0,0,0,0.5); z-index: 1035;
      }
      .mobile-overlay.show { display: block; }
      .topbar { padding: 0 16px; }
      .page-content { padding: 16px; }
    }

    /* ===== MOBILE HAMBURGER ===== */
    .hamburger-btn {
      display: none; width: 38px; height: 38px; border-radius: 10px;
      align-items: center; justify-content: center;
      background: #f1f5f9; border: 1px solid var(--border-color);
      cursor: pointer; font-size: 18px; color: #475569;
      transition: var(--transition); flex-shrink: 0;
    }
    [data-bs-theme="dark"] .hamburger-btn { background: #334155; border-color: #475569; color: #94a3b8; }
    @media (max-width: 768px) { .hamburger-btn { display: flex; } }

    /* ===== CHART CONTAINERS ===== */
    .chart-container { min-height: 320px; }
  </style>
</head>
<body>
<div class="mobile-overlay" id="mobileOverlay"></div>
<%- include('sidebar') %>
<div id="main-content">
  <%- include('topbar') %>
  <div class="page-content">
    <%- include('alert') %>
