<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %>PT Digital Nusantara</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.45.0/tabler-icons.min.css">
  <style>
    :root {
      --sidebar-width: 250px;
    }
    body { margin: 0; font-family: system-ui, -apple-system, sans-serif; }
    #miniSidebar {
      position: fixed; top: 0; left: 0; bottom: 0; width: var(--sidebar-width);
      background: var(--bs-body-bg); border-right: 1px solid var(--bs-border-color);
      overflow-y: auto; z-index: 1000;
    }
    #content { margin-left: var(--sidebar-width); min-height: 100vh; }
    .custom-container { max-width: 1400px; margin: 0 auto; }
    [data-bs-theme="dark"] #miniSidebar { background: #1a1a2e; border-color: #2a2a3e; }
    .nav-link { color: var(--bs-body-color); padding: 10px 20px; display: flex; align-items: center; gap: 10px; text-decoration: none; border-radius: 0; }
    .nav-link:hover, .nav-link.active { background: var(--bs-primary); color: white; }
    .nav-icon { width: 20px; text-align: center; font-size: 18px; }
    .brand-logo { padding: 20px; border-bottom: 1px solid var(--bs-border-color); }
  </style>
</head>
<body>
<div id="miniSidebar">
  <div class="brand-logo">
    <a href="/dashboard" class="d-flex align-items-center gap-2 text-decoration-none">
      <span class="fw-bold fs-5 text-primary">PT Digital Nusantara</span>
    </a>
  </div>
  <%- include('sidebar') %>
</div>
<div id="content" class="position-relative">
  <%- include('topbar') %>
  <div class="custom-container p-4">
    <%- include('alert') %>
