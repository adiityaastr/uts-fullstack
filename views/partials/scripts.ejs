<script src="https://cdn.jsdelivr.net/npm/apexcharts@3.52.0/dist/apexcharts.min.js"></script>
<script>
function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('mobileOverlay').classList.toggle('show');
}
document.getElementById('mobileOverlay').addEventListener('click', toggleSidebar);
setTimeout(function() {
  document.querySelectorAll('.alert').forEach(function(a) {
    setTimeout(function() { var bs = bootstrap.Alert.getInstance(a); if (bs) bs.close(); }, 4000);
  });
}, 300);
</script>
