<%- include('../partials/header', { currentPage: 'upload', title: 'Upload Excel' }) %>
<div class="page-header">
  <h4>Upload Excel</h4>
  <p>Import data karyawan dari file Excel atau CSV</p>
</div>
<div class="row g-3">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header"><h6 class="mb-0 fw-bold"><i class="ti ti-upload me-2"></i>Upload File</h6></div>
      <div class="card-body">
        <form method="POST" action="/upload/excel" enctype="multipart/form-data">
          <div class="mb-3">
            <label class="form-label">Pilih File (.xlsx, .xls, .csv)</label>
            <input type="file" name="excelfile" class="form-control" accept=".xlsx,.xls,.csv" required>
          </div>
          <button type="submit" class="btn btn-primary"><i class="ti ti-upload me-1"></i>Upload & Import</button>
        </form>
        <div class="mt-3 p-3 rounded" style="background:#f8fafc;border:1px solid #e2e8f0;">
          <small class="text-muted">
            <strong>Format kolom Excel:</strong><br>
            employee_code, full_name, gender, birth_date, email, phone_number, address, city, province, postal_code, division, position, salary, join_date, employment_status, education, marital_status, emergency_contact, emergency_phone
          </small>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card">
      <div class="card-header"><h6 class="mb-0 fw-bold"><i class="ti ti-files me-2"></i>File Terupload</h6></div>
      <div class="card-body">
        <% if (files.length === 0) { %>
        <div class="text-center py-4 text-muted">
          <i class="ti ti-file-off fs-1 d-block mb-2 opacity-25"></i>Belum ada file terupload
        </div>
        <% } else { %>
        <table class="table table-sm">
          <thead><tr><th>Nama File</th><th>Ukuran</th><th>Aksi</th></tr></thead>
          <tbody>
          <% files.forEach(f => { %>
          <tr>
            <td style="font-weight:500;"><i class="ti ti-file me-1"></i><%= f.name %></td>
            <td><small class="text-muted"><%= (f.size / 1024).toFixed(1) %> KB</small></td>
            <td>
              <form method="POST" action="/upload/file/<%= f.name %>/delete" style="display:inline" onsubmit="return confirm('Hapus file ini?')">
                <button class="btn btn-sm" style="background:#fef2f2;color:#dc2626;border-color:#fecaca;"><i class="ti ti-trash"></i> Hapus</button>
              </form>
            </td>
          </tr>
          <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/scripts') %>
