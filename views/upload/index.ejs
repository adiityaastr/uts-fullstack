<%- include('../partials/header', { currentPage: 'upload', title: 'Upload Excel' }) %>
<div class="page-header">
  <h4>Upload Excel</h4>
  <p>Import data karyawan dari file Excel atau CSV</p>
</div>
<div class="row g-3">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header"><h6 class="mb-0 fw-bold" style="font-size:14px;">Upload File</h6></div>
      <div class="card-body">
        <form method="POST" action="/upload/excel" enctype="multipart/form-data">
          <div class="mb-3">
            <label class="form-label">Pilih File (.xlsx, .xls, .csv)</label>
            <input type="file" name="excelfile" class="form-control" accept=".xlsx,.xls,.csv" required>
          </div>
          <button type="submit" class="btn btn-primary"><i class="ti ti-upload me-1"></i>Upload & Import</button>
        </form>
        <div class="mt-3 p-3" style="background:#fafaf8;border:1px solid var(--border);border-radius:8px;">
          <small style="color:#999;font-size:11px;">
            <strong style="color:#666;">Format kolom:</strong><br>
            employee_code, full_name, gender, birth_date, email, phone_number, address, city, province, postal_code, division, position, salary, join_date, employment_status, education, marital_status, emergency_contact, emergency_phone
          </small>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card">
      <div class="card-header"><h6 class="mb-0 fw-bold" style="font-size:14px;">File Terupload</h6></div>
      <div class="card-body">
        <% if (files.length === 0) { %>
        <div class="text-center py-4" style="color:#aaa;">
          <i class="ti ti-file-off" style="font-size:32px;display:block;margin-bottom:8px;opacity:0.3;"></i>Belum ada file
        </div>
        <% } else { %>
        <table class="table table-sm">
          <thead><tr><th>Nama File</th><th>Ukuran</th><th>Aksi</th></tr></thead>
          <tbody>
          <% files.forEach(f => { %>
          <tr>
            <td style="font-weight:500;font-size:13px;"><i class="ti ti-file me-1"></i><%= f.name %></td>
            <td><small style="color:#999;"><%= (f.size / 1024).toFixed(1) %> KB</small></td>
            <td>
              <form method="POST" action="/upload/file/<%= f.name %>/delete" style="display:inline" onsubmit="return confirm('Hapus file ini?')">
                <button class="btn btn-sm btn-light" style="color:#dc2626;"><i class="ti ti-trash"></i></button>
              </form>
            </td>
          </tr>
          <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/scripts') %>
