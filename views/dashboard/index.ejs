<%- include('../partials/header', { currentPage: 'dashboard', title: 'Dashboard' }) %>
<div class="page-header">
  <h4>Dashboard</h4>
  <p>Ringkasan data karyawan PT Digital Nusantara</p>
</div>

<div class="row g-3 mb-4">
  <div class="col-xl-3 col-md-6">
    <div class="stat-card">
      <div class="stat-icon" style="background:linear-gradient(135deg,#e0e7ff,#c7d2fe);color:#4f46e5;">
        <i class="ti ti-users-group"></i>
      </div>
      <div>
        <div class="stat-value"><%= totalKaryawan %></div>
        <div class="stat-label">Total Karyawan</div>
      </div>
    </div>
  </div>
  <div class="col-xl-3 col-md-6">
    <div class="stat-card">
      <div class="stat-icon" style="background:linear-gradient(135deg,#d1fae5,#a7f3d0);color:#059669;">
        <i class="ti ti-building"></i>
      </div>
      <div>
        <div class="stat-value"><%= totalDivisi %></div>
        <div class="stat-label">Total Divisi</div>
      </div>
    </div>
  </div>
  <div class="col-xl-3 col-md-6">
    <div class="stat-card">
      <div class="stat-icon" style="background:linear-gradient(135deg,#e0f2fe,#bae6fd);color:#0284c7;">
        <i class="ti ti-user-shield"></i>
      </div>
      <div>
        <div class="stat-value"><%= totalUser %></div>
        <div class="stat-label">Total User</div>
      </div>
    </div>
  </div>
  <div class="col-xl-3 col-md-6">
    <div class="stat-card">
      <div class="stat-icon" style="background:linear-gradient(135deg,#fef3c7,#fde68a);color:#d97706;">
        <i class="ti ti-check"></i>
      </div>
      <div>
        <div class="stat-value"><%= totalAktif %></div>
        <div class="stat-label">Karyawan Aktif</div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header"><h6 class="mb-0 fw-bold">Karyawan per Divisi</h6></div>
      <div class="card-body"><div class="chart-container" id="chartDivision"></div></div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card">
      <div class="card-header"><h6 class="mb-0 fw-bold">Karyawan per Status</h6></div>
      <div class="card-body"><div class="chart-container" id="chartStatus"></div></div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var divisionData = <%- JSON.stringify(byDivision) %>;
  var statusData = <%- JSON.stringify(byStatus) %>;

  new ApexCharts(document.querySelector('#chartDivision'), {
    chart: { type: 'donut', height: 340, fontFamily: 'Inter' },
    labels: divisionData.map(function(d) { return d.division; }),
    series: divisionData.map(function(d) { return d.total; }),
    legend: { position: 'bottom', fontSize: '13px', fontWeight: 500 },
    colors: ['#4f46e5','#059669','#d97706','#dc2626','#7c3aed','#0284c7','#0891b2','#16a34a'],
    plotOptions: { pie: { donut: { size: '55%' } } },
    dataLabels: { style: { fontSize: '11px' } }
  }).render();

  new ApexCharts(document.querySelector('#chartStatus'), {
    chart: { type: 'bar', height: 340, fontFamily: 'Inter' },
    xaxis: { categories: statusData.map(function(d) { return d.status; }) },
    series: [{ name: 'Total', data: statusData.map(function(d) { return d.total; }) }],
    colors: ['#4f46e5'],
    plotOptions: { bar: { borderRadius: 6, columnWidth: '50%' } },
    dataLabels: { enabled: false }
  }).render();
});
</script>
<%- include('../partials/scripts') %>
