<%- include('../partials/header', { currentPage: 'employees', title: 'Detail Karyawan' }) %>
<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
  <div>
    <h4>Detail Karyawan</h4>
    <p>Informasi lengkap data karyawan</p>
  </div>
  <div class="d-flex gap-2">
    <% if (locals.user && locals.user.role === 'Admin') { %>
    <a href="/employees/<%= employee.id %>/edit" class="btn btn-warning btn-sm text-white"><i class="ti ti-edit me-1"></i>Edit</a>
    <% } %>
    <a href="/employees" class="btn btn-light btn-sm"><i class="ti ti-arrow-left me-1"></i>Kembali</a>
  </div>
</div>

<div class="row g-3">
  <div class="col-md-3">
    <div class="card">
      <div class="card-body text-center py-4">
        <div class="detail-avatar mx-auto mb-3">
          <% if (employee.profile_photo) { %>
          <img src="<%= employee.profile_photo %>" alt="<%= employee.full_name %>" style="width:100%;height:100%;object-fit:cover;border-radius:20px;">
          <% } else { %>
          <i class="ti ti-user" style="font-size:56px;color:#a5b4fc;"></i>
          <% } %>
        </div>
        <h6 class="fw-bold mb-1"><%= employee.full_name %></h6>
        <span class="badge bg-primary"><%= employee.employee_code %></span>
        <div class="mt-2">
          <span class="badge <%= employee.employment_status === 'Active' ? 'bg-success' : employee.employment_status === 'Inactive' ? 'bg-warning text-dark' : 'bg-danger' %>"><%= employee.employment_status %></span>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-9">
    <div class="card">
      <div class="card-header"><h6 class="mb-0 fw-bold">Informasi Personal</h6></div>
      <div class="table-responsive">
        <table class="table detail-info-table mb-0">
          <tr><td>Jenis Kelamin</td><td><%= employee.gender %></td></tr>
          <tr><td>Tanggal Lahir</td><td><%= employee.birth_date ? new Date(employee.birth_date).toLocaleDateString('id-ID', {year:'numeric',month:'long',day:'numeric'}) : '-' %></td></tr>
          <tr><td>Email</td><td><%= employee.email || '-' %></td></tr>
          <tr><td>No HP</td><td><%= employee.phone_number || '-' %></td></tr>
          <tr><td>Alamat</td><td><%= [employee.address, employee.city, employee.province, employee.postal_code].filter(Boolean).join(', ') || '-' %></td></tr>
          <tr><td>Pendidikan</td><td><%= employee.education || '-' %></td></tr>
          <tr><td>Status Nikah</td><td><%= employee.marital_status || '-' %></td></tr>
        </table>
      </div>
    </div>
    <div class="card mt-3">
      <div class="card-header"><h6 class="mb-0 fw-bold">Informasi Pekerjaan</h6></div>
      <div class="table-responsive">
        <table class="table detail-info-table mb-0">
          <tr><td>Divisi</td><td><strong><%= employee.division %></strong></td></tr>
          <tr><td>Jabatan</td><td><%= employee.position || '-' %></td></tr>
          <tr><td>Gaji</td><td><%= employee.salary ? 'Rp ' + Number(employee.salary).toLocaleString('id-ID') : '-' %></td></tr>
          <tr><td>Tanggal Masuk</td><td><%= employee.join_date ? new Date(employee.join_date).toLocaleDateString('id-ID', {year:'numeric',month:'long',day:'numeric'}) : '-' %></td></tr>
          <tr><td>Status</td><td><span class="badge <%= employee.employment_status === 'Active' ? 'bg-success' : employee.employment_status === 'Inactive' ? 'bg-warning text-dark' : 'bg-danger' %>"><%= employee.employment_status %></span></td></tr>
        </table>
      </div>
    </div>
    <div class="card mt-3">
      <div class="card-header"><h6 class="mb-0 fw-bold">Kontak Darurat</h6></div>
      <div class="table-responsive">
        <table class="table detail-info-table mb-0">
          <tr><td>Nama Kontak</td><td><%= employee.emergency_contact || '-' %></td></tr>
          <tr><td>Telepon</td><td><%= employee.emergency_phone || '-' %></td></tr>
        </table>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/scripts') %>
