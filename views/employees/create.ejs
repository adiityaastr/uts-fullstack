<%- include('../partials/header', { currentPage: 'employees', title: 'Tambah Karyawan' }) %>
<div class="page-header">
  <h4>Tambah Karyawan</h4>
  <p>Isi formulir untuk menambahkan data karyawan baru</p>
</div>
<div class="card">
  <div class="card-body">
    <form method="POST" action="/employees" enctype="multipart/form-data">
      <h6 class="fw-bold mb-3" style="font-size:13px;color:#999;text-transform:uppercase;letter-spacing:0.5px;">Data Pribadi</h6>
      <div class="row g-3 mb-4">
        <div class="col-md-3"><label class="form-label">Kode Karyawan *</label><input type="text" name="employee_code" class="form-control" required placeholder="EMP001"></div>
        <div class="col-md-6"><label class="form-label">Nama Lengkap *</label><input type="text" name="full_name" class="form-control" required placeholder="Nama lengkap"></div>
        <div class="col-md-3"><label class="form-label">Jenis Kelamin</label><select name="gender" class="form-select"><option value="Male">Laki-laki</option><option value="Female">Perempuan</option></select></div>
        <div class="col-md-3"><label class="form-label">Tanggal Lahir</label><input type="date" name="birth_date" class="form-control"></div>
        <div class="col-md-3"><label class="form-label">Pendidikan</label><input type="text" name="education" class="form-control" placeholder="S1 Teknik"></div>
        <div class="col-md-3"><label class="form-label">Status Nikah</label><select name="marital_status" class="form-select"><option value="Single">Belum Menikah</option><option value="Married">Menikah</option></select></div>
        <div class="col-md-3"><label class="form-label">Foto</label><input type="file" name="profile_photo" class="form-control" accept=".jpg,.jpeg,.png"><small style="color:#999;font-size:11px;">Max 2MB</small></div>
      </div>

      <h6 class="fw-bold mb-3" style="font-size:13px;color:#999;text-transform:uppercase;letter-spacing:0.5px;">Kontak & Alamat</h6>
      <div class="row g-3 mb-4">
        <div class="col-md-4"><label class="form-label">Email</label><input type="email" name="email" class="form-control" placeholder="email@example.com"></div>
        <div class="col-md-4"><label class="form-label">No HP</label><input type="text" name="phone_number" class="form-control" placeholder="08xxxxxxxx"></div>
        <div class="col-md-4"><label class="form-label">Kota</label><input type="text" name="city" class="form-control" placeholder="Kota"></div>
        <div class="col-12"><label class="form-label">Alamat</label><textarea name="address" class="form-control" rows="2" placeholder="Alamat lengkap"></textarea></div>
        <div class="col-md-6"><label class="form-label">Provinsi</label><input type="text" name="province" class="form-control" placeholder="Provinsi"></div>
        <div class="col-md-6"><label class="form-label">Kode Pos</label><input type="text" name="postal_code" class="form-control" placeholder="Kode pos"></div>
      </div>

      <h6 class="fw-bold mb-3" style="font-size:13px;color:#999;text-transform:uppercase;letter-spacing:0.5px;">Pekerjaan</h6>
      <div class="row g-3 mb-4">
        <div class="col-md-4"><label class="form-label">Divisi *</label><input type="text" name="division" class="form-control" required placeholder="IT, HR, Finance..."></div>
        <div class="col-md-4"><label class="form-label">Jabatan</label><input type="text" name="position" class="form-control" placeholder="Jabatan"></div>
        <div class="col-md-4"><label class="form-label">Gaji</label><input type="number" step="0.01" name="salary" class="form-control" placeholder="0"></div>
        <div class="col-md-3"><label class="form-label">Tanggal Masuk</label><input type="date" name="join_date" class="form-control"></div>
        <div class="col-md-3"><label class="form-label">Status</label><select name="employment_status" class="form-select"><option value="Active">Active</option><option value="Inactive">Inactive</option><option value="Resigned">Resigned</option></select></div>
        <div class="col-md-3"><label class="form-label">Kontak Darurat</label><input type="text" name="emergency_contact" class="form-control" placeholder="Nama"></div>
        <div class="col-md-3"><label class="form-label">Telp Darurat</label><input type="text" name="emergency_phone" class="form-control" placeholder="Nomor"></div>
      </div>

      <div class="d-flex gap-2 pt-2" style="border-top:1px solid var(--border);padding-top:16px;">
        <button type="submit" class="btn btn-primary"><i class="ti ti-check me-1"></i>Simpan</button>
        <a href="/employees" class="btn btn-light">Batal</a>
      </div>
    </form>
  </div>
</div>
<%- include('../partials/scripts') %>
